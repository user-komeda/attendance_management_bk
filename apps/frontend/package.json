{
  "name": "frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "infisicalLauncher --path=/microCms/solid/local  -- yarn vinxi dev",
    "build": "vinxi build",
    "start": "vinxi start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "infisicalLauncher --path=/microCms/solid/local  --  yarn vitest run --coverage",
    "test:e2e": "yarn playwright test",
    "test:e2e:ui": "yarn playwright test --ui",
    "generate:api-types": "openapi-typescript ../backend/openApi/openapi.yaml -o src/schema/apiTypes.ts　&& yarn generate:api-aliases",
    "generate:api-aliases": "node scripts/generate-api-aliases.mjs",
    "check": "yarn generate:api-types && yarn concurrently 'yarn typecheck' 'yarn lint' 'yarn format' 'yarn test' 'yarn test:e2e'"
  },
  "dependencies": {
    "@kobalte/core": "^0.13.11",
    "@solidjs/router": "^0.16.1",
    "@solidjs/start": "^1.3.2",
    "@tabler/icons-solidjs": "^3.44.0",
    "@tailwindcss/vite": "4.3.1",
    "@tanstack/solid-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "jose": "^6.2.3",
    "solid-js": "^1.9.13",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "4.3.1",
    "tailwindcss-animate": "^1.0.7",
    "valibot": "^1.4.1",
    "vinxi": "^0.5.11"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@playwright/test": "1.61.1",
    "@solidjs/testing-library": "0.8.10",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/user-event": "14.6.1",
    "@types/jsdom": "28.0.3",
    "@types/node": "25.9.4",
    "@vitest/coverage-v8": "4.1.9",
    "@vitest/eslint-plugin": "1.6.20",
    "concurrently": "10.0.3",
    "dotenv-cli": "11.0.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-no-relative-import-paths": "1.6.1",
    "eslint-plugin-playwright": "2.10.4",
    "eslint-plugin-solid": "0.14.5",
    "eslint-plugin-testing-library": "7.16.2",
    "eslint-plugin-unused-imports": "4.4.1",
    "infisicalLauncher": "git+ssh://git@github.com:user-komeda/infisicalLauncher.git",
    "jsdom": "29.1.1",
    "openapi-typescript": "7.13.0",
    "prettier": "3.8.5",
    "prettier-plugin-tailwindcss": "0.8.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0",
    "vite": "8.1.0",
    "vite-plugin-solid": "2.11.12",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "yarn@4.17.0"
}
