{
  "name": "attendance_management_bk",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check": "turbo run check",
    "compose:up": "infisicalLauncher --path=/postgres/local --cmd=docker compose up -d",
    "compose:down": "infisicalLauncher  --path=/postgres/local --cmd=docker compose down"
  },
  "devDependencies": {
    "dotenv": "17.4.2",
    "infisicalLauncher": "git+ssh://git@github.com:user-komeda/infisicalLauncher.git",
    "lefthook": "2.1.5",
    "turbo": "2.9.6"
  },
  "packageManager": "yarn@4.14.1",
  "dependencies": {
    "concurrently": "^9.2.1",
    "redis": "^5.10.0",
    "uuid": "^13.0.0"
  }
}
