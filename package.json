{
  "name": "attendance_management_bk",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check": "turbo run check",
    "compose:up": "infisicalLauncher --path=/postgres/local -- docker compose up -d",
    "compose:upAll": "infisicalLauncher --path=/postgres/local -- docker compose --profile frontend --profile backend up -d --build",
    "compose:down": "docker compose --profile frontend --profile backend down",
    "compose:downV": "docker compose --profile frontend --profile backend down -v"
  },
  "devDependencies": {
    "dotenv": "17.4.2",
    "infisicalLauncher": "git+ssh://git@github.com:user-komeda/infisicalLauncher.git",
    "lefthook": "2.1.9",
    "turbo": "2.10.0"
  },
  "packageManager": "yarn@4.17.0",
  "dependencies": {
    "concurrently": "^10.0.0",
    "redis": "^6.0.0",
    "uuid": "^14.0.0"
  }
}
